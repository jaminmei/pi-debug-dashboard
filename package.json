{
  "name": "@ricoyudog/pi-debug-dashboard",
  "version": "0.1.0",
  "description": "Real-time debug dashboard for the pi coding agent — browser-based session visualization with SSE",
  "type": "module",
  "keywords": ["pi-package", "pi-debug", "dashboard"],
  "license": "MIT",
  "author": "ricoyudog",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ricoyudog/pi-debug-dashboard.git"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "import": "./src/server.ts"
    }
  },
  "files": [
    "src/"
  ],
  "pi": {
    "extensions": ["./src/index.ts"]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.75.0"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "@types/node": "^22.0.0"
  }
}
